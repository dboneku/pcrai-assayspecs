rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Only dboneku@gmail.com (authenticated via Google) can read/write their own document.
    // Each user's assay data is stored under assayConsole/{uid}.
    match /assayConsole/{userId} {
      allow read, write: if request.auth != null
                         && request.auth.uid == userId
                         && request.auth.token.email == 'dboneku@gmail.com';
    }
  }
}
